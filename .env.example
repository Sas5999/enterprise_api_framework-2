# ============================================================
# Enterprise API Framework — Environment Configuration
# ============================================================
# COPY this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ── Runtime environment ───────────────────────────────────
# Values: dev | staging | uat | prod
ENV=dev

# ── Base URLs (one per environment) ──────────────────────
BASE_URL_DEV=https://reqres.in
BASE_URL_STAGING=https://reqres.in
BASE_URL_UAT=https://reqres.in
BASE_URL_PROD=https://reqres.in

# ── Authentication ────────────────────────────────────────
API_KEY=
CLIENT_ID=
CLIENT_SECRET=
AUTH_TOKEN_URL=

# ── HTTP settings ─────────────────────────────────────────
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_BACKOFF=0.5
CONNECTION_POOL_SIZE=10

# ── TLS / Proxy ───────────────────────────────────────────
SSL_VERIFY=true
CLIENT_CERT_PATH=
HTTP_PROXY=

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_TO_FILE=true
LOG_FILE_PATH=logs/test_run.log
LOG_JSON=false

# ── Reporting ─────────────────────────────────────────────
ALLURE_RESULTS_DIR=allure-results
HTML_REPORT_PATH=reports/report.html

# ── Performance SLAs (milliseconds) ──────────────────────
SLA_READ_MS=2000
SLA_WRITE_MS=3000
SLA_DELETE_MS=2000

# ── Parallelism ───────────────────────────────────────────
PARALLEL_WORKERS=4

# ── Test data ─────────────────────────────────────────────
TEST_DATA_DIR=data
